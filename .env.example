APP_ENV=local
GATEWAY_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=
DATABASE_URL=sqlite:///data/shuihuo_killer.db
LLM_PROVIDER=mock
LLM_MODEL=mimo-v2.5-pro
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_API_PATH=/chat/completions
LLM_API_KEY=
LLM_AUTH_HEADER=api-key
LLM_AUTH_SCHEME=
LLM_RESPONSE_CONTENT_PATH=choices.0.message.content
LLM_EXTRA_BODY_JSON=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
ASR_PROVIDER=stub
ASR_BASE_URL=
ASR_API_PATH=/transcribe
ASR_API_KEY=
ASR_AUTH_HEADER=Authorization
ASR_AUTH_SCHEME=Bearer
ASR_TEXT_PATH=text
ASR_SPEAKER_PATH=speaker
ASR_START_MS_PATH=start_ms
ASR_END_MS_PATH=end_ms
ASR_IS_FINAL_PATH=is_final
ASR_CONFIDENCE_PATH=confidence
ASR_TIMEOUT_SECONDS=30
ASR_INTERVIEWER_CHANNELS=0,left,interviewer
ASR_CANDIDATE_CHANNELS=1,right,candidate
PROBE_MIN_ANSWER_CHARS=20
PROBE_MIN_INTERVAL_MS=1000
PROBE_REQUIRE_TOPIC_MATCH=true
PROBE_TOPIC_KEYWORDS=项目,技术,架构,方案,决策,优化,性能,指标,数据,负责,实现,上线,故障,异常,成本,延迟,吞吐,FastAPI,LLM,Python
SPEAKER_DIARIZATION_PROVIDER=local
SPEAKER_DIARIZATION_BASE_URL=
SPEAKER_DIARIZATION_API_PATH=/diarize
SPEAKER_DIARIZATION_API_KEY=
SPEAKER_DIARIZATION_AUTH_HEADER=Authorization
SPEAKER_DIARIZATION_AUTH_SCHEME=Bearer
SPEAKER_DIARIZATION_SPEAKER_PATH=speaker
SPEAKER_DIARIZATION_TIMEOUT_SECONDS=10
SIGNAL_ENABLED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_BACKEND=local
RATE_LIMIT_REQUESTS_PER_MINUTE=120
REDIS_RATE_LIMIT_PREFIX=shuihuo:rate_limit
OFFLINE_TASK_BACKEND=local
OFFLINE_TASK_EXECUTION=sync
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_PREFIX=shuihuo
JD_VECTOR_BACKEND=local
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=shuihuo-killer
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_REGION=us-east-1
REPORT_DIR=data/reports
